# Configuração do Banco de Dados MySQL
# Formato: mysql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=mysql://agendamento:sua-senha-aqui@localhost:3306/agendamento_entregas

# Porta do servidor web
PORT=3000

# Chave secreta para JWT (gere uma senha longa e aleatória)
JWT_SECRET=gerar-uma-senha-secreta-longa-e-aleatoria-aqui

# Ambiente (production ou development)
NODE_ENV=production
